{
  "name": "contact-ms",
  "version": "1.0.0",
  "description": "Contact microservice — receives messages and project requests, sends emails via SES",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:coverage": "jest --coverage",
