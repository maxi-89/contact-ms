## Infrastructure Layer

### DynamoDB Client

```typescript
// src/infrastructure/dynamodb/dynamodbClient.ts
import { DynamoDBClient } from '@aws-sdk/client-dynamodb';
import { DynamoDBDocumentClient } from '@aws-sdk/lib-dynamodb';

const client = new DynamoDBClient({
  region: process.env.AWS_REGION ?? 'us-east-1',
  ...(process.env.IS_OFFLINE === 'true' && {
    endpoint: process.env.DYNAMODB_ENDPOINT ?? 'http://localhost:8000',
    credentials: { accessKeyId: 'local', secretAccessKey: 'local' },
  }),
});

export const dynamodb = DynamoDBDocumentClient.from(client);
```

### Repository Implementation

```typescript
// src/infrastructure/dynamodb/FooRepository.ts
import { PutCommand, GetCommand } from '@aws-sdk/lib-dynamodb';
import { IFooRepository } from '../../domain/repositories/IFooRepository';
import { Foo } from '../../domain/models/Foo';
import { dynamodb } from './dynamodbClient';

const TABLE_NAME = process.env.DYNAMODB_TABLE!;

export class FooRepository implements IFooRepository {
  async save(foo: Foo): Promise<void> {
    await dynamodb.send(new PutCommand({
      TableName: TABLE_NAME,
      Item: {
        PK: `FOO#${foo.id}`,
        SK: `FOO#${foo.id}`,
        id: foo.id,
        name: foo.name,
        createdAt: foo.createdAt,
        entityType: 'FOO',
      },
    }));
  }

  async findById(id: string): Promise<Foo | null> {
    const result = await dynamodb.send(new GetCommand({
      TableName: TABLE_NAME,
      Key: { PK: `FOO#${id}`, SK: `FOO#${id}` },
    }));

    if (!result.Item) return null;

    return new Foo({
      id: result.Item.id,
      name: result.Item.name,
      createdAt: result.Item.createdAt,
    });
  }
}
```

